{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build console",
      "type": "shell",
      "command": "cargo",
      "args": [
        "build",
        "--bin",
        "roggo-agent-console"
      ],
      "problemMatcher": ["$rustc"],
      "group": "build"
    },
    {
      "label": "build console release",
      "type": "shell",
      "command": "cargo",
      "args": [
        "build",
        "--release",
        "--bin",
        "roggo-agent-console"
      ],
      "problemMatcher": ["$rustc"],
      "group": "build"
    }
  ]
}